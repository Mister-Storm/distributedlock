{
  "title": "DistributedLock - Logs & Observability",
  "uid": "distributedlock-logs",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "distributedlock",
    "raft",
    "loki"
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Node",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki-distributedlock"
        },
        "query": "label_values(service)",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "$__all"
          },
          {
            "selected": false,
            "text": "INFO",
            "value": "INFO"
          },
          {
            "selected": false,
            "text": "WARN",
            "value": "WARN"
          },
          {
            "selected": false,
            "text": "ERROR",
            "value": "ERROR"
          }
        ],
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "allValue": ".+",
        "query": "INFO,WARN,ERROR"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "All Logs",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-distributedlock"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"$level\"}",
          "refId": "A",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 2,
      "title": "Warnings & Errors",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-distributedlock"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"WARN|ERROR\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Raft State Transitions",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-distributedlock"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} |= \"transitioned\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Log Rate by Node",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-distributedlock"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"$service\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Rate by Node",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-distributedlock"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"$service\", level=\"ERROR\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{service}} errors"
        },
        {
          "expr": "sum by (service) (rate({service=~\"$service\", level=\"WARN\"}[1m]))",
          "refId": "B",
          "legendFormat": "{{service}} warns"
        }
      ]
    },
    {
      "id": 6,
      "title": "Lock Operations",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-distributedlock"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", operation=~\"POST /lock|DELETE /lock|PUT /lock/renew\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Replication Events",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-distributedlock"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} |~ \"[Rr]eplica|[Qq]uorum|[Cc]ommit\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Election Events",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-distributedlock"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=~\"$service\"} |~ \"[Ee]lection|LEADER|CANDIDATE|FOLLOWER|[Vv]ote\"",
          "refId": "A"
        }
      ]
    }
  ]
}